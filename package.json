{
	"name": "mantine-reduce-css",
	"type": "module",
	"version": "2.3.5",
	"description": "cli tool for reducing global css for mantine",
	"main": "dist/index.js",
	"bin": {
		"mantine-reduce-css": "dist/index.js"
	},
	"files": [
		"dist/**/*.js"
	],
	"scripts": {
		"build": "rollup -c",
		"start": "tsx src/index.ts",
		"fix": "biome check --fix",
		"test": "vitest",
		"gen": "tsx scripts2/index.ts"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hilmoo/mantine-reduce-css.git"
	},
	"keywords": [
		"mantine"
	],
	"author": "hilmoo",
	"license": "MIT",
	"dependencies": {
		"cac": "^6.7.14",
		"fast-glob": "^3.3.3",
		"oxc-parser": "^0.110.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.5",
		"@rollup/plugin-commonjs": "^28.0.6",
		"@rollup/plugin-json": "^6.1.0",
		"@rollup/plugin-node-resolve": "^16.0.2",
		"@rollup/plugin-typescript": "^12.1.4",
		"@types/node": "^24.0.12",
		"rollup": "^4.52.4",
		"tslib": "^2.8.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	}
