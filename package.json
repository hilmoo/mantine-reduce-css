{
	"name": "mantine-reduce-css",
	"type": "module",
	"version": "1.1.2",
	"description": "cli tool for reducing global css for mantine",
	"bin": {
		"mantine-reduce-css": "./dist/index.js"
	},
	"scripts": {
		"build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js",
		"start": "tsx src/index.ts",
		"fix": "biome check --fix",
		"fmt": "biome format",
		"test:fixture": "tsx src/index.ts gen --config test/package.json",
		"test:vite-min-template": "tsx src/index.ts gen --config test/fixture/vite-min-template/package.json"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hilmoo/mantine-reduce-css.git"
	},
	"keywords": [
		"mantine"
	],
	"author": "hilmoo",
	"license": "MIT",
	"dependencies": {
		"cac": "^6.7.14",
		"es-module-lexer": "^1.7.0",
		"fast-glob": "^3.3.3",
		"esbuild": "^0.25.6",
		"pkg-types": "^2.3.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.5",
		"@types/node": "^24.0.12",
		"tsx": "^4.20.3",
		"typescript": "^5.8.3"
	}
}